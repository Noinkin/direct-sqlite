{
  "name": "@direct-sqlite/core",
  "description": "High-performance, zero-allocation abstraction layer for SQLite instances.  Normalizes differences between `better-sqlite3`, `node:sqlite` and `bun:sqlite`.",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "noinkin.github.io/direct-sqlite",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noinkin/direct-sqlite.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "extract": "api-extractor run --local",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@direct-sqlite/schema": "workspace:*"
  }
}